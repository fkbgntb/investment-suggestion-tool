# Application settings. Copy this file to .env for local development.
INVEST_ENVIRONMENT=development
INVEST_DEBUG=false
INVEST_HOST=127.0.0.1
INVEST_PORT=8000
INVEST_LOG_LEVEL=INFO
INVEST_DATA_DIR=E:/data
INVEST_DATABASE_URL=sqlite:///E:/data/investment_tool.db
INVEST_PORTFOLIO_WORKSPACE_ID=personal-demo
INVEST_PORTFOLIO_REFERENCE_VALUE=
INVEST_RAW_DOCUMENT_RETENTION_DAYS=90
INVEST_REQUIRE_EXTERNAL_DATA_DIR=true
INVEST_ALLOW_PUBLIC_BIND=false
# Optional local/network proxy used only by the collector HTTP client.
# INVEST_COLLECTOR_PROXY_URL=http://127.0.0.1:7897
INVEST_GDELT_MAX_RECORDS=50
INVEST_GDELT_MAX_DOCUMENTS_PER_DAY=500
# Free Alpha Vantage accounts currently allow 25 requests/day; keep a local reserve.
INVEST_ALPHA_VANTAGE_API_KEY=
INVEST_ALPHA_VANTAGE_MAX_RECORDS=50
INVEST_ALPHA_VANTAGE_MAX_CALLS_PER_DAY=20
INVEST_ALPHA_VANTAGE_MAX_DOCUMENTS_PER_DAY=500
# Required only before making automated SEC requests; keep the real address local.
# INVEST_SEC_CONTACT_EMAIL=your-contact@example.com
INVEST_SEC_MAX_FILINGS_PER_COMPANY=50

# Keep the real value only in .env or a system environment variable.
DEEPSEEK_API_KEY=
INVEST_DEEPSEEK_MODEL=deepseek-v4-flash
INVEST_DEEPSEEK_MAX_CALLS_PER_DAY=20
INVEST_DEEPSEEK_DAILY_TOKEN_BUDGET=100000
INVEST_DEEPSEEK_SYNTHESIS_MAX_CALLS_PER_DAY=10
INVEST_DEEPSEEK_SYNTHESIS_DAILY_TOKEN_BUDGET=50000
# INVEST_BACKUP_PASSPHRASE=use-a-long-random-local-secret
